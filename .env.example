# Environment
NODE_ENV=development

# Timezone
TZ=America/Argentina/Cordoba
DEFAULT_TIMEZONE=America/Argentina/Cordoba

# Admin numbers (comma separated, with country code, no + sign)
# Example: 5491112345678,5491187654321
ADMIN_NUMBERS=5491112345678

# Logging
LOG_LEVEL=info

# Database
DB_PATH=./storage/database.sqlite

# Scheduler
# Check every N minutes for birthdays to send
SCHEDULER_CHECK_INTERVAL=1
