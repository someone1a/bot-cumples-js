# Environment
NODE_ENV=development

# Timezone
TZ=America/Argentina/Cordoba
DEFAULT_TIMEZONE=America/Argentina/Cordoba

# Authorized numbers (comma separated, with country code, no + sign)
# Only these numbers can use the bot commands
# Example: 5491112345678,5491187654321
AUTHORIZED_NUMBERS=5491112345678

# Logging
LOG_LEVEL=info

# Database
DB_PATH=./storage/database.sqlite

# Scheduler
# Check every N minutes for birthdays to send
SCHEDULER_CHECK_INTERVAL=1

# Web Interface
# Set to false to disable web interface
WEB_ENABLED=true
WEB_PORT=3000

# Web Panel Security
# Set a password to protect the web panel (leave empty to disable)
WEB_PANEL_PASSWORD=
